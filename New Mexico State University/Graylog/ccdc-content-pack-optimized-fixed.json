   "data": {
    "title": {
     "@type": "string",
     "@value": "Win - Failed Logon 4625"
    },
    "description": {
     "@type": "string",
     "@value": "Failed logon indicator"
    },
    "source": {
     "@type": "string",
     "@value": "rule \"Win 4625\"\nwhen\ntl($e)==4625\nthen\nsf(\"evt\",\"logon_fail\");\nsf(\"sev\",\"warn\");\nend"
    }
   }
  },
  {
