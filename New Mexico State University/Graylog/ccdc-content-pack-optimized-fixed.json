   "data": {
    "title": {
     "@type": "string",
     "@value": "Win - Success Logon 4624"
    },
    "description": {
     "@type": "string",
     "@value": "Success logon events"
    },
    "source": {
     "@type": "string",
     "@value": "rule \"Win 4624\"\nwhen\ntl($e)==4624\nthen\nsf(\"evt\",\"logon_ok\");\nsf(\"sev\",\"info\");\nlet lt=ts($m.LogonType);\nif(lt==\"10\"|lt==\"3\"){\nsf(\"sev\",\"notice\");\n}\nend"
    }
   }
  },
