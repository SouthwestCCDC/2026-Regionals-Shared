   ],
   "data": {
    "title": {
     "@type": "string",
     "@value": "Win - Kerberoast 4769"
    },
    "description": {
     "@type": "string",
     "@value": "TGS RC4 kerberoasting"
    },
    "source": {
     "@type": "string",
     "@value": "rule \"Win Krb\"\nwhen\ntl($e)==4769\nthen\nsf(\"evt\",\"krb_tgs\");\nsf(\"sev\",\"info\");\nlet et=ts($m.TicketEncryptionType);\nif(et==\"0x17\"|et==\"23\"){\nsf(\"sev\",\"high\");\n}\nend"
    }
   }
