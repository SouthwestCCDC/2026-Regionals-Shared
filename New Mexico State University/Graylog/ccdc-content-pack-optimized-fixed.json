   "id": "rule-linux-ssh",
   "constraints": [
    {
     "type": "server-version",
     "version": ">=3.0.0"
    }
   ],
   "data": {
    "title": {
     "@type": "string",
     "@value": "Linux - SSH Fail"
    },
    "description": {
     "@type": "string",
     "@value": "Failed SSH login"
    },
    "source": {
     "@type": "string",
     "@value": "rule \"SSH Fail\"\nwhen\nhas(ts($msg),\"Failed password\")|has(ts($msg),\"Invalid user\")|has(ts($msg),\"authentication failure\")\nthen\nsf(\"evt\",\"ssh_fail\");\nsf(\"sev\",\"warn\");\nend"
    }
   }
  },
  {
   "v": "1",
   "type": {
    "name": "pipeline_rule",
