    },
    "source": {
     "@type": "string",
     "@value": "rule \"Shell\"\nwhen\nhas(ts($msg),\"/bin/bash -i\")|has(ts($msg),\"nc -e\")|has(ts($msg),\"| bash\")\nthen\nsf(\"evt\",\"rev_shell\");\nsf(\"sev\",\"crit\");\nend"
