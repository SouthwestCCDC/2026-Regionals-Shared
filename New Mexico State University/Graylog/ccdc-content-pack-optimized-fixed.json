   },
   "id": "rule-tag-windows",
   "constraints": [
    {
     "type": "server-version",
     "version": ">=3.0.0"
    }
   ],
   "data": {
    "title": {
     "@type": "string",
     "@value": "Tag Windows Source"
    },
    "description": {
     "@type": "string",
     "@value": "Tag Winlogbeat messages"
    },
    "source": {
     "@type": "string",
     "@value": "rule \"Tag Windows\"\nwhen\nhas_field(\"winlog_event_id\")|has_field(\"event_id\")\nthen\nsf(\"log_src\",\"win\");\nend"
    }
   }
  },
  {
