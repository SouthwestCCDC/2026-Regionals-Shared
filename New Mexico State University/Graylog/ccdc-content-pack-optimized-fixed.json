  {
   "v": "1",
   "type": {
    "name": "pipeline_rule",
    "version": "1"
   },
   "id": "rule-win-proc",
   "constraints": [
    {
     "type": "server-version",
     "version": ">=3.0.0"
    }
   ],
   "data": {
    "title": {
     "@type": "string",
     "@value": "Win - Process 4688"
    },
    "description": {
     "@type": "string",
     "@value": "Process creation flags mimikatz/LOLBins"
    },
    "source": {
     "@type": "string",
     "@value": "rule \"Win Proc\"\nwhen\ntl($e)==4688\nthen\nsf(\"evt\",\"proc_new\");\nsf(\"sev\",\"info\");\nlet p=lc(ts($m.NewProcessName));\nlet c=lc(ts($m.CommandLine));\nif(has(p,\"mimikatz\")|has(c,\"sekurlsa\")){\nsf(\"sev\",\"crit\");\n}else if(has(c,\"iex\")|has(c,\"downloadstring\")){\nsf(\"sev\",\"high\");\n}\nend"
    }
   }
  },
  {
   "v": "1",
   "type": {
    "name": "pipeline_rule",
    "version": "1"
   },
   "id": "rule-win-ps",
   "constraints": [
    {
     "type": "server-version",
     "version": ">=3.0.0"
    }
   ],
   "data": {
    "title": {
     "@type": "string",
     "@value": "Win - PS Block 4104"
    },
    "description": {
     "@type": "string",
     "@value": "PowerShell script block logging"
    },
    "source": {
     "@type": "string",
     "@value": "rule \"Win PS\"\nwhen\ntl($e)==4104\nthen\nsf(\"evt\",\"ps_block\");\nsf(\"sev\",\"notice\");\nlet sb=lc(ts($msg));\nif(has(sb,\"mimikatz\")|has(sb,\"invoke-mimikatz\")){\nsf(\"sev\",\"crit\");\n}else if(has(sb,\"iex\")|has(sb,\"downloadstring\")){\nsf(\"sev\",\"high\");\n}\nend"
    }
   }
  },
