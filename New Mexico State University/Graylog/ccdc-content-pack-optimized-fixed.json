   ],
   "data": {
    "title": {
     "@type": "string",
     "@value": "Linux - SSH Success"
    },
    "description": {
     "@type": "string",
     "@value": "Successful SSH login"
    },
    "source": {
     "@type": "string",
     "@value": "rule \"SSH OK\"\nwhen\nhas(ts($msg),\"Accepted password\")|has(ts($msg),\"Accepted publickey\")\nthen\nsf(\"evt\",\"ssh_ok\");\nsf(\"sev\",\"notice\");\nend"
    }
   }
  },
  {
   "v": "1",
   "type": {
    "name": "pipeline_rule",
    "version": "1"
   },
   "id": "rule-linux-sudo",
   "constraints": [
    {
     "type": "server-version",
     "version": ">=3.0.0"
    }
   ],
   "data": {
    "title": {
     "@type": "string",
     "@value": "Linux - Sudo"
    },
    "description": {
     "@type": "string",
     "@value": "Sudo execution"
    },
    "source": {
     "@type": "string",
     "@value": "rule \"Sudo\"\nwhen\nhas(ts($a),\"sudo\")|has(ts($msg),\"sudo:\")\nthen\nsf(\"evt\",\"sudo\");\nsf(\"sev\",\"notice\");\nif(has(ts($msg),\"NOT in sudoers\")|has(ts($msg),\"authentication failure\")){\nsf(\"sev\",\"high\");\n}\nend"
    }
   }
  },
